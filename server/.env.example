# ========================================
# BACKEND CONFIGURATION FILE (.env)
# 
# 📌 IMPORTANT: 
#   1. Copy this file to .env
#   2. Fill in your MongoDB connection string
#   3. Change JWT_SECRET to a strong key
#   4. Do NOT commit .env to Git!
# ========================================

# === SERVER CONFIG ===
PORT=5000
NODE_ENV=development

# === MONGODB CONNECTION ===
# 📍 Choose ONE option below:
#
# Option 1: MongoDB Atlas (Cloud) ⭐ RECOMMENDED
#   mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/shipper-admin?retryWrites=true&w=majority
#
# Option 2: Docker MongoDB
#   mongodb://admin:admin123@localhost:27017/shipper-admin?authSource=admin
#
# Option 3: Local MongoDB
#   mongodb://localhost:27017/shipper-admin
MONGODB_URI=mongodb://localhost:27017/shipper-admin

# === JWT SECURITY ===
# ⚠️ CHANGE THESE VALUES! Use strong random strings
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d

# === FRONTEND URL ===
# URL của React frontend (cho CORS)
CLIENT_URL=http://localhost:5173

# === CORS ALLOWED ORIGINS (Optional) ===
# Danh sách origins được phép gửi request tới backend
# Nếu không set, sẽ update từ code
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://10.0.2.2:5000
